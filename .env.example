# Resonance environment variables.
# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.
# The app boots without these in a degraded/dev mode; features that need a given
# service are disabled until its key is present (see each package's CLAUDE.md).

# --- Database (ADR-0004) ---
# Neon Postgres connection string (pgvector enabled). Used by @resonance/db.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# --- Auth (ADR-0005) ---
# Better Auth. Generate a strong secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# --- AI (ADR-0009) ---
# Vercel AI Gateway key (preferred — unified, BYOK, failover). Default Claude models.
AI_GATEWAY_API_KEY=""
# Direct Anthropic key (fallback if not using the gateway).
ANTHROPIC_API_KEY=""
# Voyage embeddings (matching backbone, ADR-0010).
VOYAGE_API_KEY=""

# --- Email (ADR-0005) ---
# Resend — transactional email (magic links, notifications).
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Resonance <noreply@example.com>"

# --- Payments (ADR-0006 — stubbed; not required to run the scaffold) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- Media storage (ADR-0007 — deferred behind StoragePort; not required yet) ---
# BLOB_READ_WRITE_TOKEN=""

# --- Live-smoke gate (ADR-0018 §3) ---
# `pnpm verify:live` exercises the model, embedding, email, and DB wiring FOR REAL. It SKIPS
# (exit 0) unless all creds are present: AI (AI_GATEWAY_API_KEY, or ANTHROPIC_API_KEY+VOYAGE_API_KEY,
# above) + email (RESEND_API_KEY above) + DB (DATABASE_URL above) + the destination below.
# The address the smoke email is sent to (must be deliverable by your Resend sender).
VERIFY_LIVE_EMAIL_TO=""

# --- Testing note (ADR-0018) ---
# There is NO runtime fakes flag. Shipped code is live-by-default; fakes are injected in tests via
# DI. The ONE exception is the full-flow Playwright E2E, which boots the app under an isolated,
# prod-guarded harness — `E2E_HARNESS=1` is set by apps/web/playwright.config.ts, NOT here.

{
  "name": "@resonance/auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./testing": {
      "types": "./src/testing/fake-mail.ts",
      "default": "./src/testing/fake-mail.ts"
    }

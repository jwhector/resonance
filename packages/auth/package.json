    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@resonance/eslint-config": "workspace:*",
    "@resonance/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "eslint": "^9.18.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.2"
  }

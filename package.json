{
  "name": "resonance",
  "version": "0.0.0",
  "private": true,
  "description": "Resonance — an AI-centric e-commerce and community platform. Find and support what resonates with you.",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "verify:live": "node scripts/verify-live.mjs",
    "check:workspace": "node scripts/check-workspace-integrity.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@resonance/ai": "workspace:*",
    "@resonance/auth": "workspace:*",
    "@resonance/db": "workspace:*",
    "@resonance/tsconfig": "workspace:*",
    "drizzle-orm": "0.45.2",
    "prettier": "^3.4.2",
    "tsx": "4.22.4",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
